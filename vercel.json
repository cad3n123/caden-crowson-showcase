{
  "redirects": [
    {
      "source": "/infinite-matter",
      "destination": "/infinite-matter/",
      "permanent": true
    },
    {
      "source": "/infinite-factory",
      "destination": "/infinite-factory/",
      "permanent": true
    },
    {
      "source": "/sand-timer",
      "destination": "/sand-timer/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/infinite-matter/:match*",
      "destination": "https://infinite-matter.vercel.app/:match*"
    },
    {
      "source": "/infinite-factory/:match*",
      "destination": "https://infinite-factory.vercel.app/:match*"
    },
    {
      "source": "/sand-timer/:match*",
      "destination": "https://sand-timer.vercel.app/:match*"
    }
  ]
}
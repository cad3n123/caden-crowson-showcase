{
  "redirects": [
    {
      "source": "/infinite-matter",
      "destination": "/infinite-matter/",
      "permanent": true
    },
    {
      "source": "/infinite-factory",
      "destination": "/infinite-factory/",
      "permanent": true
    },
    {
      "source": "/sand-timer",
      "destination": "/sand-timer/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/infinite-matter/(.*)",
      "destination": "https://infinite-matter.vercel.app/$1"
    },
    {
      "source": "/infinite-factory/(.*)",
      "destination": "https://infinite-factory.vercel.app/$1"
    },
    {
      "source": "/sand-timer/(.*)",
      "destination": "https://sand-timer.vercel.app/$1"
    }
  ]
}